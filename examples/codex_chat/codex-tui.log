+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import shlex
+import subprocess
+import sys
+
+
+BENCH_SCRIPT = "/workspace/video_bench/scripts/benchmark_t2v_vae_decode.py"
+DEFAULT_FAMILIES = [
+    "wan_t2v_a14b",
+    "cogvideox15_5b",
+    "hunyuanvideo15_720p",
+    "ltx2_19b",
+    "opensora_v2_256px",
+]
+
+
+def build_command(family: str, args: argparse.Namespace) -> list[str]:
+    cmd = [
+        sys.executable,
+        BENCH_SCRIPT,
+        "--family",
+        family,
+        "--device",
+        args.device,
+        "--model-dtype",
+        args.model_dtype,
+        "--warmup-iters",
+        str(args.warmup_iters),
+        "--iters",
+        str(args.iters),
+    ]
+    if args.skip_stream:
+        cmd.append("--skip-stream")
+    if args.skip_full:
+        cmd.append("--skip-full")
+    if args.stream_chunk_latent_frames is not None:
+        cmd.extend(["--stream-chunk-latent-frames", str(args.stream_chunk_latent_frames)])
+    return cmd
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser(
+        description="Print or execute the per-model VAE decode benchmark commands."
+    )
+    parser.add_argument("--device", default="cuda:0")
+    parser.add_argument("--model-dtype", default="bf16")
+    parser.add_argument("--warmup-iters", type=int, default=1)
+    parser.add_argument("--iters", type=int, default=5)
+    parser.add_argument("--stream-chunk-latent-frames", type=int)
+    parser.add_argument("--skip-stream", action="store_true")
+    parser.add_argument("--skip-full", action="store_true")
+    parser.add_argument(
+        "--execute",
+        action="store_true",
+        help="Actually run the benchmark commands. Without this flag the script only prints them.",
+    )
+    parser.add_argument(
+        "--include-mochi",
+        action="store_true",
+        help="Also print the Mochi benchmark command. It has no default latent sample yet, so you must override --latent-path manually when you run it.",
+    )
+    args = parser.parse_args()
+
+    families = list(DEFAULT_FAMILIES)
+    if args.include_mochi:
+        families.append("mochi_1")
+
+    commands = [build_command(family, args) for family in families]
+    for family, cmd in zip(families, commands, strict=True):
+        print(f"# {family}")
+        print(shlex.join(cmd))
+
+    if not args.execute:
+        return
+
+    for cmd in commands:
+        subprocess.run(cmd, check=True)
+
+
+if __name__ == "__main__":
+    main()
