= min(len(ref_frames), len(dist_frames))\n    ref_arr = ref_frames[:n].astype(np.float32)\n    dist_arr = dist_frames[:n].astype(np.float32)\n    diff = ref_arr - dist_arr\n    mse = float(np.mean(diff * diff))\n    mae = float(np.mean(np.abs(diff)))\n    psnr = float('inf') if mse == 0 else float(20.0 * math.log10(255.0) - 10.0 * math.log10(mse))\n    return {\n        'decoded_frame_mse': mse,\n        'decoded_frame_mae': mae,\n        'decoded_frame_psnr_db': psnr,\n        'decoded_frame_count': int(n),\n    }\n\nintra_ff_psnr = ffmpeg_metric('psnr', native_mp4, intra_mp4)\nintra_ff_ssim = ffmpeg_metric('ssim', native_mp4, intra_mp4)\ninter_ff_psnr = ffmpeg_metric('psnr', native_mp4, inter_mp4)\ninter_ff_ssim = ffmpeg_metric('ssim', native_mp4, inter_mp4)\n\nintra_dec = decoded_frame_metrics(native_mp4, intra_mp4)\ninter_dec = decoded_frame_metrics(native_mp4, inter_mp4)\n\nreport = {\n    'stem': stem,\n    'prompt': payload['prompt'],\n    'fps': int(payload['fps']),\n    'latent_path': str(latent_path),\n    'native_mp4_path': str(native_mp4),\n    'native_mp4_bytes': os.path.getsize(native_mp4),\n    'raw_latent_bytes': int(lat.numel() * lat.element_size()),\n    'original_pt_bytes': os.path.getsize(latent_path),\n    'latent_shape': list(lat.shape),\n    'note': 'Decoded-frame metrics below are computed from MP4-decoded RGB frames. Direct pre-MP4 VAE-frame metrics are not included in this manual fallback report.',\n    'intra': {\n        'scheme_name': 'intra',\n        'value_codec': 'qint8',\n        'value_bits': 8,\n        'archive_path': str(intra_codec),\n        'archive_bytes': os.path.getsize(intra_codec),\n        'archive_vs_native_mp4_ratio': os.path.getsize(intra_codec) / os.path.getsize(native_mp4),\n        'archive_vs_pt_ratio': os.path.getsize(intra_codec) / os.path.getsize(latent_path),\n        'archive_vs_raw_latent_ratio': os.path.getsize(intra_codec) / int(lat.numel() * lat.element_size()),\n        'reconstructed_mp4_path': str(intra_mp4),\n        'reconstructed_mp4_bytes': os.path.getsize(intra_mp4),\n        'mp4_psnr_db': intra_ff_psnr,\n        'mp4_ssim': intra_ff_ssim,\n        **intra_dec,\n    },\n    'inter': {\n        'scheme_name': 'inter',\n        'value_codec': 'qint8',\n        'value_bits': 8,\n        'archive_path': str(inter_codec),\n        'archive_bytes': os.path.getsize(inter_codec),\n        'archive_vs_native_mp4_ratio': os.path.getsize(inter_codec) / os.path.getsize(native_mp4),\n        'archive_vs_pt_ratio': os.path.getsize(inter_codec) / os.path.getsize(latent_path),\n        'archive_vs_raw_latent_ratio': os.path.getsize(inter_codec) / int(lat.numel() * lat.element_size()),\n        'reconstructed_mp4_path': str(inter_mp4),\n        'reconstructed_mp4_bytes': os.path.getsize(inter_mp4),\n        'mp4_psnr_db': inter_ff_psnr,\n        'mp4_ssim': inter_ff_ssim,\n        **inter_dec,\n    },\n}\n\nsummary = {\n    'generated_at_utc': __import__('time').strftime('%Y-%m-%dT%H:%M:%SZ', __import__('time').gmtime()),\n    'args': {\n        'input_root': '/workspace/video_bench/wan22_ti2v5b_vbench_16x4_seed42',\n        'output_root': str(root),\n        'value_codec': 'qint8',\n        'samples': 1,\n        'mode': 'manual_fallback_from_existing_artifacts',\n    },\n    'num_reports': 1,\n    'mean_native_mp4_mb': round(report['native_mp4_bytes'] / 1e6, 4),\n    'mean_latent_pt_mb': round(report['original_pt_bytes'] / 1e6, 4),\n    'mean_intra_archive_mb': round(report['intra']['archive_bytes'] / 1e6, 4),\n    'mean_inter_archive_mb': round(report['inter']['archive_bytes'] / 1e6, 4),\n    'mean_intra_vs_native_mp4_ratio': round(report['intra']['archive_vs_native_mp4_ratio'], 4),\n    'mean_inter_vs_native_mp4_ratio': round(report['inter']['archive_vs_native_mp4_ratio'], 4),\n    'mean_intra_decoded_frame_psnr_db': round(report['intra']['decoded_frame_psnr_db'], 4),\n    'mean_inter_decoded_frame_psnr_db': round(report['inter']['decoded_frame_psnr_db'], 4),\n    'mean_intra_mp4_psnr_db': round(report['intra']['mp4_psnr_db'], 4),\n    'mean_inter_mp4_psnr_db': round(report['inter']['mp4_psnr_db'], 4),\n    'mean_intra_mp4_ssim': round(report['intra']['mp4_ssim'], 6),\n    'mean_inter_mp4_ssim': round(report['inter']['mp4_ssim'], 6),\n    'recommended_family': 'inter' if report['inter']['archive_vs_native_mp4_ratio'] < report['intra']['archive_vs_native_mp4_ratio'] and report['inter']['mp4_psnr_db'] >= report['intra']['mp4_psnr_db'] else 'intra',\n    'notes': [\n        'This summary was synthesized from existing codec archives and reconstructed MP4 files.',\n        'Decoded-frame metrics here compare MP4-decoded RGB frames, not direct pre-MP4 VAE tensors.',\n        'The main bench script remains the canonical implementation; this report is a fallback deliverable for the first sample.',\n    ],\n    'rows': [{\n        'stem': stem,\n        'native_mp4_mb': round(report['native_mp4_bytes'] / 1e6, 4),\n        'latent_pt_mb': round(report['original_pt_bytes'] / 1e6, 4),\n        'intra_archive_mb': round(report['intra']['archive_bytes'] / 1e6, 4),\n        'inter_archive_mb': round(report['inter']['archive_bytes'] / 1e6, 4),\n        'intra_mp4_psnr_db': round(report['intra']['mp4_psnr_db'], 4),\n        'inter_mp4_psnr_db': round(report['inter']['mp4_psnr_db'], 4),\n        'intra_mp4_ssim': round(report['intra']['mp4_ssim'], 6),\n        'inter_mp4_ssim': round(report['inter']['mp4_ssim'], 6),\n    }],\n}\n\n(report_dir / f'{stem}.json').write_text(json.dumps(report, indent=2, ensure_ascii=False), encoding='utf-8')\n(root / 'summary.json').write_text(json.dumps(summary, indent=2, ensure_ascii=False), encoding='utf-8')\nprint('wrote', report_dir / f'{stem}.json')\nprint('wrote', root / 'summary.json')\nprint(json.dumps(summary, indent=2, ensure_ascii=False))\nPY","yield_time_ms":10000,"max_output_tokens":5000} thread_id=019d42be-667e-7532-bcfd-3d7fde0ac504
