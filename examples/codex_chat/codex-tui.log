+
+def torch_dtype_from_name(name: str) -> torch.dtype:
+    mapping = {
+        "float32": torch.float32,
+        "fp32": torch.float32,
+        "float16": torch.float16,
+        "fp16": torch.float16,
+        "bfloat16": torch.bfloat16,
+        "bf16": torch.bfloat16,
+    }
+    key = name.lower()
+    if key not in mapping:
+        raise ValueError(f"Unsupported dtype: {name}")
+    return mapping[key]
+
+
+def require_diffusers_attr(name: str):
+    import diffusers
+
+    value = getattr(diffusers, name, None)
+    if value is None:
+        raise ImportError(
+            f"Current diffusers build ({diffusers.__version__}) does not provide {name}. "
+            "Upgrade diffusers before running this benchmark."
+        )
+    return value
+
+
+def load_latents_blob(path: str | Path) -> tuple[torch.Tensor, dict[str, Any]]:
+    path = Path(path)
+    blob = torch.load(path, map_location="cpu")
+    meta: dict[str, Any] = {"latent_path": str(path)}
+    if isinstance(blob, dict):
+        meta.update({k: v for k, v in blob.items() if k != "latents"})
+        if "latents" in blob:
+            tensor = blob["latents"]
+        else:
+            raise KeyError(f"{path} does not contain a 'latents' entry.")
+    elif torch.is_tensor(blob):
+        tensor = blob
+    else:
+        raise TypeError(f"Unsupported latent blob type: {type(blob)!r}")
+    return tensor.detach().cpu(), meta
+
+
+def canonical_meta(meta: dict[str, Any], args: argparse.Namespace) -> dict[str, Any]:
+    out = dict(meta)
+    if "width" not in out and getattr(args, "width", None) is not None:
+        out["width"] = args.width
+    if "height" not in out and getattr(args, "height", None) is not None:
+        out["height"] = args.height
+    if "num_frames" not in out and getattr(args, "num_frames", None) is not None:
+        out["num_frames"] = args.num_frames
+    return out
+
+
+def ceil_div(n: int, d: int) -> int:
+    return (n + d - 1) // d
+
+
+def tensor_frame_count(tensor: Any, time_dim: int | None = None) -> int:
+    if torch.is_tensor(tensor):
+        if time_dim is not None:
+            return int(tensor.shape[time_dim])
+        if tensor.ndim == 5:
+            return int(tensor.shape[2])
+        if tensor.ndim == 4:
+            return int(tensor.shape[1])
+    if isinstance(tensor, list):
+        return len(tensor)
+    raise TypeError(f"Cannot infer frame count from object type {type(tensor)!r}")
+
+
+def measure_call(fn, synchronize: bool = True):
+    if synchronize and torch.cuda.is_available():
+        torch.cuda.synchronize()
+    t0 = time.perf_counter()
+    out = fn()
+    if synchronize and torch.cuda.is_available():
+        torch.cuda.synchronize()
+    dt = time.perf_counter() - t0
+    return out, dt
+
+
+def summarize_timings(times: list[float], total_frames: int) -> dict[str, Any]:
+    mean_sec = statistics.mean(times)
+    median_sec = statistics.median(times)
+    std_sec = statistics.pstdev(times) if len(times) > 1 else 0.0
+    fps = total_frames / mean_sec if mean_sec > 0 else float("inf")
+    return {
+        "iterations": len(times),
+        "timings_sec": times,
+        "mean_sec": mean_sec,
+        "median_sec": median_sec,
+        "std_sec": std_sec,
+        "frames_per_sec": fps,
+        "ms_per_frame": (mean_sec * 1000.0 / total_frames) if total_frames > 0 else None,
+        "total_frames_per_decode": total_frames,
+    }
+
+
+def summarize_stream(times: list[float], frames: list[int], stable_cv_threshold: float) -> dict[str, Any]:
+    total_frames = sum(frames)
+    total_sec = sum(times)
+    first_latency = times[0] if times else None
+    first_frames = frames[0] if frames else None
+    steady_times = times[1:]
+    steady_frames = frames[1:]
+    steady_total_frames = sum(steady_frames)
+    steady_total_sec = sum(steady_times)
+    steady_fps = steady_total_frames / steady_total_sec if steady_total_sec > 0 else None
+    chunk_fps = [(f / t) if t > 0 else None for f, t in zip(frames, times, strict=True)]
+
+    if steady_times:
+        mean_steady = statistics.mean(steady_times)
+        std_steady = statistics.pstdev(steady_times) if len(steady_times) > 1 else 0.0
+        steady_cv = std_steady / mean_steady if mean_steady > 0 else None
+    else:
+        mean_steady = None
+        std_steady = None
+        steady_cv = None
+
+    return {
+        "chunk_count": len(times),
+        "chunk_times_sec": times,
+        "chunk_frames": frames,
+        "chunk_frames_per_sec": chunk_fps,
+        "first_output_latency_sec": first_latency,
+        "first_output_frames": first_frames,
+        "exact_first_frame_latency_supported": bool(first_frames == 1),
+        "total_stream_sec": total_sec,
+        "total_frames": total_frames,
+        "avg_frames_per_sec": (total_frames / total_sec) if total_sec > 0 else None,
+        "steady_state_total_frames": steady_total_frames,
+        "steady_state_total_sec": steady_total_sec,
+        "steady_state_frames_per_sec": steady_fps,
+        "steady_state_chunk_mean_sec": mean_steady,
+        "steady_state_chunk_std_sec": std_steady,
+        "steady_state_chunk_time_cv": steady_cv,
+        "appears_stable_after_first_chunk": bool(
+            steady_cv is not None and steady_cv <= stable_cv_threshold
+        ),
+    }
+
+
+@dataclass
+class AdapterBundle:
+    model: Any
+    decode_fn: Any
+    stream_split_fn: Any
+    cleanup_fn: Any
+    output_time_dim: int | None
+    adapter_name: str
+
+
+def build_wan_adapter(args: argparse.Namespace, latent_meta: dict[str, Any]) -> AdapterBundle:
+    sys.path.insert(0, args.wan_root)
+    if args.family == "wan_t2v_a14b":
+        from wan.modules.vae2_1 import Wan2_1_VAE  # noqa: WPS433
+
+        vae = Wan2_1_VAE(
+            vae_pth=str(Path(args.ckpt_dir) / "Wan2.1_VAE.pth"),
+            dtype=torch_dtype_from_name(args.model_dtype),
+            device=args.device,
+        )
+    else:
+        from wan.modules.vae2_2 import Wan2_2_VAE  # noqa: WPS433
+
+        vae = Wan2_2_VAE(
+            vae_pth=str(Path(args.ckpt_dir) / "Wan2.2_VAE.pth"),
+            dtype=torch_dtype_from_name(args.model_dtype),
+            device=args.device,
+        )
+
+    def decode_fn(latents: torch.Tensor):
+        video = vae.decode([latents.to(device=args.device, dtype=torch.float32)])[0]
+        return video.detach().cpu()
+
+    def split_fn(latents: torch.Tensor, chunk_latent_frames: int):
+        total_t = int(latents.shape[1])
+        return [latents[:, i : i + chunk_latent_frames].contiguous() for i in range(0, total_t, chunk_latent_frames)]
+
+    return AdapterBundle(
+        model=vae,
+        decode_fn=decode_fn,
+        stream_split_fn=split_fn,
+        cleanup_fn=lambda: None,
+        output_time_dim=1,
+        adapter_name="wan_native_vae",
+    )
+
+
+def build_diffusers_adapter(args: argparse.Namespace, latent_meta: dict[str, Any]) -> AdapterBundle:
+    import diffusers  # noqa: WPS433
+
+    dtype = torch_dtype_from_name(args.model_dtype)
+    family = latent_meta.get("family") or args.diffusers_family
+    family = family or args.family
+
+    if family == "cog":
+        Pipeline = require_diffusers_attr("CogVideoXPipeline")
+        pipe = Pipeline.from_pretrained(args.model_id, torch_dtype=dtype)
+    elif family == "hunyuan":
+        AutoencoderKLHunyuanVideo15 = require_diffusers_attr("AutoencoderKLHunyuanVideo15")
+        pipe = None
+        vae = AutoencoderKLHunyuanVideo15.from_pretrained(
+            args.model_id,
+            subfolder="vae",
+            torch_dtype=dtype,
+        )
+    elif family == "mochi":
+        Pipeline = require_diffusers_attr("MochiPipeline")
+        pipe = Pipeline.from_pretrained(args.model_id, torch_dtype=dtype)
+    elif family == "ltx":
+        try:
+            Pipeline = require_diffusers_attr("LTX2Pipeline")
+        except ImportError:
+            Pipeline = require_diffusers_attr("LTXPipeline")
+        pipe = Pipeline.from_pretrained(args.model_id, torch_dtype=dtype)
+    else:
+        raise ValueError(f"Unsupported diffusers family: {family}")
+
+    if family != "hunyuan":
+        pipe.enable_model_cpu_offload()
+        vae = pipe.vae
+        vae.to(args.device, dtype=dtype)
+    else:
+        vae.to(args.device, dtype=dtype)
+
+    scaling_factor = getattr(getattr(vae, "config", None), "scaling_factor", 1.0) or 1.0
+
+    def decode_direct(latents: torch.Tensor):
+        lat = latents.to(args.device)
+        if family == "hunyuan":
+            decoded = vae.decode(lat.to(dtype=torch.float32) / scaling_factor, return_dict=False)[0]
+        else:
+            if hasattr(pipe, "decode_latents"):
+                decoded = pipe.decode_latents(lat.to(dtype=dtype))
+            else:
+                decoded = vae.decode(lat.to(dtype=dtype) / scaling_factor, return_dict=False)[0]
+        if torch.is_tensor(decoded):
+            return decoded.detach().cpu()
+        return decoded
+
+    def split_temporal(latents: torch.Tensor, chunk_latent_frames: int):
+        if family == "cog":
+            total_t = int(latents.shape[1])
+            return [latents[:, i : i + chunk_latent_frames].contiguous() for i in range(0, total_t, chunk_latent_frames)]
+        if family == "hunyuan":
+            total_t = int(latents.shape[2])
+            return [latents[:, :, i : i + chunk_latent_frames].contiguous() for i in range(0, total_t, chunk_latent_frames)]
+        if family == "ltx":
+            width = int(latent_meta["width"])
+            height = int(latent_meta["height"])
+            num_frames = int(latent_meta["num_frames"])
+            latent_h = ceil_div(height, args.space_compression_ratio)
+            latent_w = ceil_div(width, args.space_compression_ratio)
+            latent_t = ceil_div(num_frames, args.time_compression_ratio)
+            tokens_per_t = latent_h * latent_w
+            expected_tokens = latent_t * tokens_per_t
+            if latents.shape[1] != expected_tokens:
+                raise ValueError(
+                    f"LTX token count mismatch: expected {expected_tokens}, got {latents.shape[1]}."
+                )
+            chunks = []
+            for i in range(0, latent_t, chunk_latent_frames):
+                token_start = i * tokens_per_t
+                token_end = min(i + chunk_latent_frames, latent_t) * tokens_per_t
+                chunks.append(latents[:, token_start:token_end].contiguous())
+            return chunks
+        if family == "mochi":
+            raise NotImplementedError(
+                "Mochi streaming benchmark needs the latent temporal layout confirmed first. "
+                "Full VAE decode timing is implemented; streaming split is intentionally left explicit."
+            )
+        raise ValueError(f"Unsupported family: {family}")
+
+    return AdapterBundle(
+        model=vae if family == "hunyuan" else pipe,
+        decode_fn=decode_direct,
+        stream_split_fn=split_temporal,
+        cleanup_fn=lambda: None,
+        output_time_dim=2 if family == "hunyuan" else None,
+        adapter_name=f"diffusers_{family}",
+    )
+
+
+def build_opensora_adapter(args: argparse.Namespace, latent_meta: dict[str, Any]) -> AdapterBundle:
+    sys.path.insert(0, args.opensora_root)
+    from mmengine import Config  # noqa: WPS433
+    from opensora.registry import MODELS, build_module  # noqa: WPS433
+
+    cfg = Config.fromfile(args.opensora_config)
+    dtype = torch_dtype_from_name(args.model_dtype)
+    vae = build_module(cfg.ae, MODELS, device_map=args.device, torch_dtype=dtype).eval()
+
+    def decode_fn(latents: torch.Tensor):
+        decoded = vae.decode(latents.to(args.device, dtype=dtype))
+        return decoded.detach().cpu()
+
+    def split_fn(latents: torch.Tensor, chunk_latent_frames: int):
+        total_t = int(latents.shape[2])
+        return [latents[:, :, i : i + chunk_latent_frames].contiguous() for i in range(0, total_t, chunk_latent_frames)]
+
+    return AdapterBundle(
+        model=vae,
+        decode_fn=decode_fn,
+        stream_split_fn=split_fn,
+        cleanup_fn=lambda: None,
+        output_time_dim=2,
+        adapter_name="opensora_cfg_ae",
+    )
+
+
+def build_adapter(args: argparse.Namespace, latent_meta: dict[str, Any]) -> AdapterBundle:
+    if args.family in {"wan_t2v_a14b", "wan_ti2v_5b"}:
+        return build_wan_adapter(args, latent_meta)
+    if args.family in {"cogvideox15_5b", "hunyuanvideo15_720p", "ltx2_19b", "mochi_1"}:
+        return build_diffusers_adapter(args, latent_meta)
+    if args.family == "opensora_v2_256px":
+        return build_opensora_adapter(args, latent_meta)
