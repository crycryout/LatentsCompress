+        "time_sec": full_dt,
+        "frames": full_frames,
+        "output_shape": list(full_video.shape),
+    }
+    del full_video
+    maybe_cleanup()
+
+    chunks = adapter.split_chunks(latents, args.stream_chunk_latent_frames)
