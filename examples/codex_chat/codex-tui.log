ight,\n        'num_frames': num_frames,\n        'fps': fps,\n        'raw_frame_bytes': raw_frame_bytes,\n        'mp4_bytes': video_path.stat().st_size,\n        'latent_file_bytes': latent_file_bytes,\n        'latent_raw_bytes': latent_raw_bytes,\n        'latent_shape': latent_shape,\n        'latent_dtype': latent_dtype,\n    })\n\nsummary_path = root / 'generated_size_report.json'\nsummary_path.write_text(json.dumps(out, indent=2, ensure_ascii=False), encoding='utf-8')\nprint(summary_path)\nprint(len(out))\nfor item in out:\n    print(item['name'])\n    print(item['latent_file_bytes'], item['raw_frame_bytes'], item['mp4_bytes'])\nPY","workdir":"/root","yield_time_ms":1000,"max_output_tokens":5000} thread_id=019d41cd-1eed-7b20-8604-a373d5f5a502
