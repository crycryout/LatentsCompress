+
+
+def apply_family_defaults(args: argparse.Namespace) -> None:
+    defaults = DEFAULT_TARGETS.get(args.family, {})
+    for key, value in defaults.items():
+        if getattr(args, key, None) in (None, ""):
+            setattr(args, key, value)
