+    parser.add_argument(
+        "--native-temporal-tiling",
+        action="store_true",
+        help="For Open-Sora only: enable its native temporal tiling switch before decode.",
+    )
+    args = parser.parse_args()
+    apply_defaults(args)
+    return args
+
